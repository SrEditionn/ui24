<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ===================== TELA DE CONFIGURAÇÃO (IP / DEMO) ===================== -->
    <LinearLayout
        android:id="@+id/setupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UI24 Remote"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conecte-se à mesa de som"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:hint="IP da mesa (ex: 192.168.1.50)"
            app:boxBackgroundColor="@color/surface_dark">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ipInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="@color/text_primary"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/connectButton"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Conectar na mesa"
            app:backgroundTint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ou"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/demoButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:text="Usar versão demo"
            app:strokeColor="@color/accent"
            android:textColor="@color/accent" />

    </LinearLayout>

    <!-- ===================== WEBVIEW EM TELA CHEIA (MODO MESA) ===================== -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/loadingSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Botão escondido (transparente) no canto: segure pressionado para desconectar
             e poder trocar o IP da mesa. Não atrapalha o uso normal. -->
        <View
            android:id="@+id/hiddenDisconnectButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="top|start"
            android:alpha="0" />

    </FrameLayout>

</FrameLayout>
