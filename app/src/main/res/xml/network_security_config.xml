<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allows plain HTTP (no TLS) to any host, since the mixer's built-in
         web server on the local network does not use HTTPS. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
